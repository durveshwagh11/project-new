{
  "arrowParens": "always",
  "bracketSpacing": true,
  "embeddedLanguageFormatting": "auto",
  "htmlWhitespaceSensitivity": "css",
  "insertPragma": false,
  "jsxSingleQuote": true,
  "proseWrap": "never",
  "quoteProps": "as-needed",
  "requirePragma": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "useTabs": true,
  "vueIndentScriptAndStyle": false,
  "printWidth": 200,
  "tabWidth": 4,
  "overrides": [
    {
      "files": "*.md",
      "options": {
        "printWidth": 200,
        "useTabs": false,
        "trailingComma": "none",
        "proseWrap": "never"
      }
    },
    {
      "files": "*.sql",
      "options": {
        "printWidth": 200,
        "useTabs": false,
        "trailingComma": "none",
        "proseWrap": "never"
      }
    }
  ]
}
