{
	"name": "@durvesh-nx/backend",
	"version": "0.0.1",
	"private": true,
	"nx": {
		"targets": {
			"build": {
				"executor": "nx:run-commands",
				"options": {
					"command": "webpack-cli build",
					"args": [
						"--node-env=production"
					],
					"cwd": "apps/backend"
				},
				"configurations": {
					"development": {
						"args": [
							"--node-env=development"
						]
					}
				}
			},
			"serve": {
				"continuous": true,
				"executor": "@nx/js:node",
				"defaultConfiguration": "development",
				"dependsOn": [
					"build"
				],
				"options": {
					"buildTarget": "@durvesh-nx/backend:build",
					"runBuildTargetDependencies": false
				},
				"configurations": {
					"development": {
						"buildTarget": "@durvesh-nx/backend:build:development"
					},
					"production": {
						"buildTarget": "@durvesh-nx/backend:build:production"
					}
				}
			},
			"test": {
				"options": {
					"passWithNoTests": true
				}
			},
			"docker:build": {
				"dependsOn": [
					"build"
				]
			}
		}
	},
	"dependencies": {
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/platform-express": "^11.0.0",
		"reflect-metadata": "^0.1.13",
		"rxjs": "^7.8.0",
		"tslib": "^2.3.0"
	},
	"devDependencies": {
		"@nestjs/testing": "^11.0.0"
	}
}
