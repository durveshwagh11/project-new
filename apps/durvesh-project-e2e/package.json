{
  "name": "@durvesh-project/durvesh-project-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@durvesh-project/durvesh-project"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/durvesh-project-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@durvesh-project/durvesh-project:build",
          "@durvesh-project/durvesh-project:serve"
        ]
      }
    }
  }
}
