{
  "name": "@durvesh-nx/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"pnpm start:backend\" \"pnpm start:frontend\" --output-style=stream",
    "start:backend": "nx serve backend --watch --output-style=stream",
    "start:frontend": "nx serve frontend --watch --output-style=stream",
    "start:infra": "docker compose -f deployment/docker-compose.start.yml up -d",
    "build": "nx run-many -t build",
    "build:backend": "nx build backend",
    "build:frontend": "nx build frontend",
    "prod": "docker compose -f deployment/docker-compose.yml up --build",
    "prod:down": "docker compose -f deployment/docker-compose.yml down",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "format": "prettier --write \"apps/backend/**/*.{js,ts,tsx,json,md,html,css,scss}\" \"apps/frontend/**/*.{js,ts,tsx,json,md,html,css,scss}\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.0.0",
    "@angular/common": "~21.0.0",
    "@angular/compiler": "~21.0.0",
    "@angular/core": "~21.0.0",
    "@angular/forms": "~21.0.0",
    "@angular/platform-browser": "~21.0.0",
    "@angular/platform-browser-dynamic": "~21.0.0",
    "@angular/router": "~21.0.0",
    "@neondatabase/serverless": "^1.0.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.0.0",
    "@angular/build": "~21.0.0",
    "@angular/compiler-cli": "~21.0.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "22.5.4",
    "@nx/docker": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/nest": "22.5.4",
    "@nx/node": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/webpack": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "~0.2.38",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/pg": "^8.18.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
