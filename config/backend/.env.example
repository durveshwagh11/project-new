# Database Configuration
# Option 1: Use connection string (recommended for production)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Option 2: Use individual connection parameters (for development)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_NAME=durvesh_project

# JWT Configuration
JWT_ACCESS_SECRET=your-secure-access-secret-here-minimum-32-characters
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-secure-refresh-secret-here-minimum-32-characters
JWT_REFRESH_EXPIRES_IN=7d

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200
