{
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "importHelpers": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "paths": {
      "@durvesh-nx/shared-types": ["libs/shared/types/src/index.ts"],
      "@durvesh-nx/backend-common": ["libs/backend-common/src/index.ts"]
    }
  }
}
